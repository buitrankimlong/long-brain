# Copy file này thành .env và điền API keys của bạn
# Copy this file to .env and fill in your API keys

# V98 API Key - dùng cho semantic search (embeddings)
# Get from: v98store.com
V98_API_KEY=sk-your-v98-api-key-here

# Duong dan toi vault cua ban (thu muc chua AI Knowledge Build/)
# Path to your vault (folder containing AI Knowledge Build/)
AI_KNOWLEDGE_VAULT=/path/to/your/AI-Build-Learning
